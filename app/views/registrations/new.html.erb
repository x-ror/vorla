<% content_for(:title) { t("auth.sign_up.title") } %>

<main class="flex min-h-screen items-center justify-center px-4 py-10">
  <div class="w-full max-w-sm animate-slide-up">
    <%= render_card(class: "w-full") do %>
      <div class="p-8">
        <div class="mb-8 text-center">
          <a href="<%= root_path %>" class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary text-primary-foreground font-extrabold text-xl mb-6" aria-label="X-ROR home">X</a>
          <h1 class="text-xl font-extrabold tracking-tight"><%= t("auth.sign_up.heading") %></h1>
          <p class="mt-1 text-sm text-muted-foreground"><%= t("auth.sign_up.subheading") %></p>
        </div>

        <%= form_with url: signup_path, class: "space-y-5" do |f| %>
          <div class="space-y-1.5">
            <label for="signup-email" class="text-sm font-medium"><%= t("auth.sign_up.email_label") %></label>
            <%= render_input name: "email_address", id: "signup-email", type: :email, placeholder: t("auth.sign_up.email_placeholder"), autocomplete: "email", required: true %>
          </div>

          <div class="space-y-1.5">
            <label for="signup-password" class="text-sm font-medium"><%= t("auth.sign_up.password_label") %></label>
            <%= render_input name: "password", id: "signup-password", type: :password, placeholder: t("auth.sign_up.password_placeholder"), autocomplete: "new-password", required: true %>
          </div>

          <div class="space-y-1.5">
            <label for="signup-password-confirm" class="text-sm font-medium"><%= t("auth.sign_up.confirm_label") %></label>
            <%= render_input name: "password_confirmation", id: "signup-password-confirm", type: :password, placeholder: t("auth.sign_up.confirm_placeholder"), autocomplete: "new-password", required: true %>
          </div>

          <div class="flex items-start gap-2">
            <input type="checkbox" name="terms_accepted" id="terms-accepted" value="1" required class="mt-0.5 h-4 w-4 shrink-0 rounded border border-input bg-background text-primary shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
            <label for="terms-accepted" class="text-xs text-muted-foreground leading-snug">
              <%= t("auth.sign_up.terms_html",
                terms_link: link_to(t("auth.sign_up.terms_of_service"), terms_path, class: "underline hover:text-foreground", target: "_blank"),
                privacy_link: link_to(t("auth.sign_up.privacy_policy"), privacy_path, class: "underline hover:text-foreground", target: "_blank"),
                cookie_link: link_to(t("auth.sign_up.cookie_policy"), cookies_path, class: "underline hover:text-foreground", target: "_blank")
              ).html_safe %>
            </label>
          </div>

          <%= render_button t("auth.sign_up.submit"), class: "w-full" %>
        <% end %>

        <div class="mt-6 text-center text-sm text-muted-foreground">
          <%= t("auth.sign_up.has_account") %> <a href="<%= login_path %>" class="font-semibold text-primary hover:underline focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm"><%= t("auth.sign_up.sign_in_link") %></a>
        </div>
      </div>
    <% end %>
  </div>
</main>

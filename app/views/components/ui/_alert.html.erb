<div
  role="alert"
  class="<%= alert_classes %> relative w-full rounded-lg border p-4 [&:has(svg)]:pl-11 [&>svg+div]:translate-y-[-3px] [&>svg]:absolute [&>svg]:left-4 [&>svg]:top-4">
  <!--prettier-ignore-->
  <% case variant.to_sym %>
  <% when :default %>
    <%= lucide_icon("terminal", class: "h-4 w-4") %>
  <% when :info %>
    <%= lucide_icon("info", class: "h-4 w-4 text-info") %>
  <% when :success %>
    <%= lucide_icon("circle-check", class: "h-4 w-4 text-success") %>
  <% when :attention %>
    <%= lucide_icon("triangle-alert", class: "h-4 w-4 text-yellow-400") %>
  <% when :error, :destructive, :danger, :alert %>
    <%= lucide_icon("circle-alert", class: "h-4 w-4") %>
  <% end if icon %>
  <h5 class="mb-1 font-medium leading-none tracking-tight"><%= title %></h5>
  <div class="text-sm [&_p]:leading-relaxed"><%= description %></div>
</div>

<% content_for(:title) { "Search History - X-ROR" } %>
<%= render "shared/navbar" %>
<main class="flex-1 pb-10">
  <div class="mx-auto max-w-2xl px-4 pt-16 text-center">
    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary" aria-hidden="true">
      <%= lucide_icon("clock", class: "h-6 w-6") %>
    </div>
    <h1 class="text-2xl font-extrabold tracking-tight">Search History</h1>
    <p class="mt-2 text-muted-foreground">Your recent searches and downloads</p>
  </div>

  <div class="mx-auto max-w-xl px-4 mt-8">
    <%# Action type filter tabs %>
    <div class="flex gap-1 mb-6">
      <%= link_to "All", history_path, class: "rounded-md px-3 py-1.5 text-xs font-medium transition-colors #{params[:type].blank? ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground'}" %>
      <% %w[download stories profile_picture analyze hashtags].each do |type| %>
        <%= link_to history_action_label(type), history_path(type: type), class: "rounded-md px-3 py-1.5 text-xs font-medium transition-colors #{params[:type] == type ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground'}" %>
      <% end %>
    </div>

    <% if @logs.any? %>
      <div class="space-y-2">
        <% @logs.each do |log| %>
          <% query = log.metadata&.dig("query") %>
          <%= render_card do %>
            <div class="flex items-center gap-4 p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background">
                <%= lucide_icon(history_action_icon(log.action_type), class: "h-4 w-4 text-primary") %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium truncate"><%= query.presence || log.action_type.humanize %></p>
                <p class="text-xs text-muted-foreground">
                  <span class="rounded bg-muted px-1.5 py-0.5 text-xs font-medium"><%= history_action_label(log.action_type) %></span>
                  &middot; <%= time_ago_in_words(log.created_at) %> ago
                </p>
              </div>
              <% if query.present? && (path = history_action_path(log.action_type, query)) %>
                <a href="<%= path %>" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground" aria-label="Repeat search">
                  <%= lucide_icon("arrow-right", class: "h-4 w-4") %>
                </a>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <%= lucide_icon("clock", class: "mx-auto h-10 w-10 text-muted-foreground/30 mb-3") %>
        <p class="text-sm text-muted-foreground">No history yet. Start using the tools and your activity will appear here.</p>
      </div>
    <% end %>
  </div>
</main>
<%= render "shared/footer" %>

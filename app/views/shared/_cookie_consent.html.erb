<div id="cookie-consent-banner"
  class="fixed bottom-0 inset-x-0 z-50 transform transition-transform duration-300"
  data-controller="cookie-consent"
  data-cookie-consent-target="banner"
  style="display:none;">
  <div class="mx-auto max-w-4xl px-4 pb-4">
    <div class="rounded-xl border border-border bg-card p-5 shadow-lg">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex-1">
          <p class="text-sm font-medium"><%= t("cookie_consent.title") %></p>
          <p class="mt-1 text-xs text-muted-foreground leading-relaxed">
            <%= t("cookie_consent.description_html",
              link: link_to(t("cookie_consent.cookie_policy"), cookies_path, class: "underline hover:text-foreground")
            ).html_safe %>
          </p>
        </div>
        <div class="flex shrink-0 items-center gap-2">
          <button type="button"
            data-action="click->cookie-consent#rejectAll"
            class="rounded-lg border border-border px-4 py-2 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground">
            <%= t("cookie_consent.reject") %>
          </button>
          <button type="button"
            data-action="click->cookie-consent#acceptAll"
            class="rounded-lg bg-primary px-4 py-2 text-xs font-semibold text-primary-foreground transition-colors hover:bg-primary/90">
            <%= t("cookie_consent.accept") %>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

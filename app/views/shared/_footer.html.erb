<footer class="mt-auto border-t border-border bg-background" role="contentinfo">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 py-8 sm:flex-row">
    <a href="/" class="flex items-center gap-2 font-semibold" aria-label="Vorla home">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-extrabold" aria-hidden="true">V</span>
      Vorla
    </a>
    <nav class="flex items-center gap-4 text-sm text-muted-foreground" aria-label="Footer navigation">
      <%= link_to "Download", download_path, class: "transition-colors hover:text-foreground focus-visible:outline-none focus-visible:text-foreground" %>
      <%= link_to "Stories", stories_path, class: "transition-colors hover:text-foreground focus-visible:outline-none focus-visible:text-foreground" %>
      <%= link_to "Pricing", pricing_path, class: "transition-colors hover:text-foreground focus-visible:outline-none focus-visible:text-foreground" %>
    </nav>
    <p class="text-sm text-muted-foreground">&copy; <%= Date.current.year %> Vorla. All rights reserved.</p>
  </div>
</footer>

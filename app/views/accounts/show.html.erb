<% content_for(:title) { "#{t('user_pages.account.title')} - #{t('site_name')}" } %>
<%= render "shared/navbar" %>
<main class="flex-1 bg-muted/50 pb-16 dark:bg-background">
  <div class="mx-auto max-w-3xl px-6 pt-12">
    <p class="text-xs font-medium uppercase tracking-widest text-muted-foreground"><%= t("user_pages.account.section") %></p>
    <h1 class="mt-1 text-3xl font-normal tracking-tight"><%= t("user_pages.account.title") %></h1>

    <%# ══ Card 1 — Data Export ══ %>
    <div class="mt-10 rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none">
      <div class="border-b border-border px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground"><%= t("user_pages.account.data_export") %></span>
      </div>
      <div class="px-6 py-5">
        <p class="text-sm text-muted-foreground leading-relaxed">
          <%= t("user_pages.account.data_export_description") %>
        </p>
        <div class="mt-4">
          <%= link_to export_account_path, class: "inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-xs font-semibold text-primary-foreground transition-colors hover:bg-primary/90" do %>
            <%= lucide_icon("download", class: "h-4 w-4") %>
            <%= t("user_pages.account.export_button") %>
          <% end %>
        </div>
      </div>
    </div>

    <%# ══ Card 2 — Delete Account ══ %>
    <div class="mt-3.5 rounded-xl border border-destructive/30 bg-card shadow-md dark:shadow-none">
      <div class="border-b border-destructive/20 px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-destructive"><%= t("user_pages.account.danger_zone") %></span>
      </div>
      <div class="px-6 py-5">
        <p class="text-sm font-medium"><%= t("user_pages.account.delete_title") %></p>
        <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
          <%= t("user_pages.account.delete_description") %>
        </p>
        <div class="mt-4">
          <button type="button"
            onclick="document.getElementById('delete-account-form').classList.toggle('hidden')"
            class="rounded-lg border border-destructive/30 bg-destructive/5 px-5 py-2.5 text-xs font-semibold text-destructive transition-colors hover:bg-destructive/10">
            <%= t("user_pages.account.delete_button") %>
          </button>
        </div>
        <%= form_with url: account_path, method: :delete, id: "delete-account-form", class: "mt-4 hidden border-t border-destructive/20 pt-4" do %>
          <p class="text-sm text-muted-foreground"><%= t("user_pages.account.delete_confirm_text") %></p>
          <div class="mt-3 flex items-end gap-3">
            <div class="flex-1">
              <input type="password" name="password" placeholder="<%= t("user_pages.account.delete_password_placeholder") %>" required autocomplete="current-password"
                class="w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm transition-colors focus:border-destructive focus:outline-none focus:ring-2 focus:ring-destructive/20 placeholder:text-muted-foreground">
            </div>
            <button type="submit"
              data-turbo-confirm="<%= t("user_pages.account.delete_turbo_confirm") %>"
              class="rounded-lg bg-destructive px-5 py-2.5 text-xs font-semibold text-destructive-foreground transition-colors hover:bg-destructive/90">
              <%= t("user_pages.account.delete_submit") %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</main>
<%= render "shared/footer" %>

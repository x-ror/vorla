<% content_for(:title) { "Profile Analyzer - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="analyzer">
  <div class="page-header container-sm">
    <div class="page-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
    </div>
    <h1>Profile Analyzer</h1>
    <p>Get detailed insights and stats on any public Instagram profile</p>
  </div>

  <div class="container-sm content-center">
    <form data-action="submit->analyzer#analyze" class="username-input-wrap">
      <span class="at-sign">@</span>
      <input type="text" data-analyzer-target="username" placeholder="username" autocomplete="off">
      <button type="submit" class="search-btn" data-analyzer-target="submitBtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>

    <div data-analyzer-target="error" style="display:none;" class="alert alert-error"></div>
    <div data-analyzer-target="result" style="display:none;"></div>
  </div>
</div>

<%= render "shared/footer" %>

<% content_for(:title) { t("pages.pricing.title") } %>
<% content_for(:seo_description) { t("pages.pricing.description") } %>
<%= render "shared/navbar" %>
<main class="flex-1 pb-10" data-controller="pricing">
  <div class="mx-auto max-w-7xl px-4 pt-16 text-center sm:px-6">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight"><%= t("pages.pricing.heading") %></h1>
    <p class="mt-3 text-muted-foreground"><%= t("pages.pricing.subheading") %></p>
    <div class="mt-8 inline-flex items-center gap-3 rounded-full border border-border bg-card px-5 py-2.5 text-sm text-muted-foreground">
      <span
        data-pricing-target="monthlyLabel"
        id="billing-monthly"
        class="active-label min-w-[70px] text-center"
      >
        <%= t("pages.pricing.monthly") %>
      </span>
      <button
        type="button"
        data-action="click->pricing#toggle"
        data-pricing-target="toggleSwitch"
        aria-label="Toggle annual billing"
        class="relative shrink-0 h-7 w-12 rounded-full bg-muted border border-border transition-colors [&.active]:bg-primary [&.active]:border-primary focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
        <span class="absolute inset-y-0 left-[4px] my-auto h-[18px] w-[18px] rounded-full bg-white shadow transition-transform duration-200 [.active_&]:translate-x-[20px]"></span>
      </button>
      <span
        data-pricing-target="annualLabel"
        id="billing-annual"
        class="inline-flex items-center gap-1.5 min-w-[90px]"
        >
        <%= t("pages.pricing.annual") %> <%= render_badge t("pages.pricing.save_badge"), variant: :secondary %>
      </span>
    </div>
  </div>
  <section class="mx-auto mt-10 grid max-w-4xl gap-5 px-4 sm:grid-cols-3 sm:px-6" aria-label="Pricing plans">
    <!-- Free -->
    <div class="rounded-lg border border-border bg-card p-8 transition-all hover:-translate-y-1 hover:shadow-md">
      <h3 class="text-sm font-semibold text-muted-foreground"><%= t("pages.pricing.free.name") %></h3>
      <div class="mt-2 text-4xl font-extrabold tracking-tight"><%= t("pages.pricing.free.price") %></div>
      <ul class="mt-6 space-y-3 text-sm text-muted-foreground" aria-label="<%= t("pages.pricing.free.name") %>">
        <% t("pages.pricing.free.features").each do |feature| %>
          <li class="flex items-center gap-2"><span class="text-success" aria-hidden="true">&#10003;</span> <%= feature %></li>
        <% end %>
        <% t("pages.pricing.free.disabled").each do |feature| %>
          <li class="flex items-center gap-2 opacity-40"><span aria-hidden="true">&#10005;</span><s> <%= feature %></s></li>
        <% end %>
      </ul>
      <div class="mt-8"><%= link_to download_path do %><%= render_button t("pages.pricing.free.cta"), variant: :outline, class: "w-full" %><% end %></div>
    </div>
    <!-- Basic -->
    <div class="relative rounded-lg border-2 border-primary bg-card p-8 shadow-lg shadow-primary/10 transition-all hover:-translate-y-1">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2"><%= render_badge t("pages.pricing.basic.badge") %></div>
      <h3 class="text-sm font-semibold text-muted-foreground"><%= t("pages.pricing.basic.name") %></h3>
      <div class="mt-2 flex items-baseline gap-1"><span class="text-4xl font-extrabold tracking-tight" data-pricing-target="basicPrice">$4</span><span class="text-muted-foreground">/mo</span></div>
      <ul class="mt-6 space-y-3 text-sm text-muted-foreground" aria-label="<%= t("pages.pricing.basic.name") %>">
        <% t("pages.pricing.basic.features").each do |feature| %>
          <li class="flex items-center gap-2"><span class="text-success" aria-hidden="true">&#10003;</span> <%= feature %></li>
        <% end %>
        <% t("pages.pricing.basic.disabled").each do |feature| %>
          <li class="flex items-center gap-2 opacity-40"><span aria-hidden="true">&#10005;</span><s> <%= feature %></s></li>
        <% end %>
      </ul>
      <div class="mt-8">
        <% if authenticated? %>
          <%= render_button t("common.get_started"), class: "w-full", disabled: true %>
        <% else %>
          <%= link_to login_path do %><%= render_button t("pages.pricing.basic.cta"), class: "w-full" %><% end %>
        <% end %>
      </div>
    </div>
    <!-- Pro -->
    <div class="rounded-lg border border-amber-200 dark:border-amber-800/40 bg-card p-8 transition-all hover:-translate-y-1 hover:shadow-md">
      <h3 class="text-sm font-semibold text-muted-foreground"><%= t("pages.pricing.pro.name") %></h3>
      <div class="mt-2 flex items-baseline gap-1"><span class="text-4xl font-extrabold tracking-tight" data-pricing-target="proPrice">$9</span><span class="text-muted-foreground">/mo</span></div>
      <ul class="mt-6 space-y-3 text-sm text-muted-foreground" aria-label="<%= t("pages.pricing.pro.name") %>">
        <% t("pages.pricing.pro.features").each do |feature| %>
          <li class="flex items-center gap-2"><span class="text-success" aria-hidden="true">&#10003;</span> <%= feature %></li>
        <% end %>
      </ul>
      <div class="mt-8">
        <% if authenticated? %>
          <%= render_button t("common.get_started"), variant: :outline, class: "w-full", disabled: true %>
        <% else %>
          <%= link_to login_path do %><%= render_button t("pages.pricing.pro.cta"), variant: :outline, class: "w-full" %><% end %>
        <% end %>
      </div>
    </div>
  </section>
  <!-- FAQ -->
  <section class="mx-auto mt-20 max-w-2xl px-4" aria-labelledby="faq-heading">
    <div class="mb-12 text-center">
      <h2 id="faq-heading" class="text-2xl font-extrabold tracking-tight"><%= t("pages.pricing.faq.heading") %></h2>
    </div>
    <div class="space-y-2">
      <%= render_accordion(title: t("pages.pricing.faq.q1"), description: t("pages.pricing.faq.a1")) %>
      <%= render_accordion(title: t("pages.pricing.faq.q2"), description: t("pages.pricing.faq.a2")) %>
      <%= render_accordion(title: t("pages.pricing.faq.q3"), description: t("pages.pricing.faq.a3")) %>
      <%= render_accordion(title: t("pages.pricing.faq.q4"), description: t("pages.pricing.faq.a4")) %>
    </div>
  </section>
</main>
<%= render "shared/footer" %>

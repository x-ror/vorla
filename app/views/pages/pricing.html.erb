<% content_for(:title) { "Pricing - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="pricing">
  <div class="page-header container">
    <h1 style="font-size:2.25rem;">Simple, honest pricing</h1>
    <p>No hidden fees. Cancel anytime. Start free.</p>

    <div class="billing-toggle" style="margin-top:32px;">
      <span data-pricing-target="monthlyLabel" class="active-label">Monthly</span>
      <button type="button" data-action="click->pricing#toggle" class="toggle-switch" data-pricing-target="toggleSwitch">
        <span class="toggle-dot"></span>
      </button>
      <span data-pricing-target="annualLabel">
        Annual
        <span class="save-badge">Save 17%</span>
      </span>
    </div>
  </div>

  <div class="pricing-grid container">
    <!-- Free -->
    <div class="pricing-card">
      <div class="plan-header">
        <h3>Free</h3>
        <div class="plan-price">
          <span class="price">Free</span>
        </div>
      </div>
      <ul class="plan-features">
        <li><span class="icon-check">&#10003;</span> Basic quality downloads</li>
        <li><span class="icon-check">&#10003;</span> Profile picture download</li>
        <li><span class="icon-check">&#10003;</span> Ad-supported experience</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Full quality & batch downloads</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Stories downloader</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Profile analyzer</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Influencer search</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Hashtag generator</li>
      </ul>
      <a href="<%= download_path %>" class="plan-cta">Start Free &rarr;</a>
    </div>

    <!-- Basic -->
    <div class="pricing-card popular">
      <div class="popular-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Most Popular
      </div>
      <div class="plan-header">
        <h3>Basic</h3>
        <div class="plan-price">
          <span class="price" data-pricing-target="basicPrice">$4</span>
          <span class="period">/mo</span>
        </div>
      </div>
      <ul class="plan-features">
        <li><span class="icon-check">&#10003;</span> Full quality downloads</li>
        <li><span class="icon-check">&#10003;</span> Batch download (carousels)</li>
        <li><span class="icon-check">&#10003;</span> Profile picture download</li>
        <li><span class="icon-check">&#10003;</span> Stories downloader</li>
        <li><span class="icon-check">&#10003;</span> Viewer & tracker</li>
        <li><span class="icon-check">&#10003;</span> Profile analyzer</li>
        <li><span class="icon-check">&#10003;</span> No ads</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Influencer search</li>
        <li class="disabled"><span class="icon-x">&#10005;</span> Hashtag generator</li>
      </ul>
      <% if authenticated? %>
        <%= button_to "Get Started", "#", class: "plan-cta primary", disabled: true %>
      <% else %>
        <a href="<%= login_path %>" class="plan-cta primary">Get Started &rarr;</a>
      <% end %>
    </div>

    <!-- Pro -->
    <div class="pricing-card gold">
      <div class="plan-header">
        <h3>Pro</h3>
        <div class="plan-price">
          <span class="price" data-pricing-target="proPrice">$9</span>
          <span class="period">/mo</span>
        </div>
      </div>
      <ul class="plan-features">
        <li><span class="icon-check">&#10003;</span> Everything in Basic</li>
        <li><span class="icon-check">&#10003;</span> Influencer search</li>
        <li><span class="icon-check">&#10003;</span> Hashtag generator</li>
        <li><span class="icon-check">&#10003;</span> Priority processing</li>
        <li><span class="icon-check">&#10003;</span> API access</li>
        <li><span class="icon-check">&#10003;</span> No ads</li>
        <li><span class="icon-check">&#10003;</span> Priority support</li>
      </ul>
      <% if authenticated? %>
        <%= button_to "Get Started", "#", class: "plan-cta", disabled: true %>
      <% else %>
        <a href="<%= login_path %>" class="plan-cta">Get Started &rarr;</a>
      <% end %>
    </div>
  </div>

  <!-- FAQ -->
  <div class="container-sm" style="margin-top:80px;">
    <div class="section-header">
      <h2>Frequently asked questions</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Can I cancel anytime?</summary>
        <p class="faq-answer">Yes, you can cancel your subscription at any time. No questions asked, no hidden fees.</p>
      </details>
      <details class="faq-item">
        <summary>Do I need an Instagram account?</summary>
        <p class="faq-answer">No. Vorla works with any public Instagram content. No login or Instagram account required.</p>
      </details>
      <details class="faq-item">
        <summary>What payment methods do you accept?</summary>
        <p class="faq-answer">We accept all major credit cards, PayPal, and Apple Pay through our secure payment partner.</p>
      </details>
      <details class="faq-item">
        <summary>Is there a download limit?</summary>
        <p class="faq-answer">Free users have a reasonable fair-use limit. Basic and Pro plans have generous limits that cover normal usage.</p>
      </details>
    </div>
  </div>
</div>

<%= render "shared/footer" %>

<% content_for(:title) { "Vorla — Download Instagram Content Instantly" } %>

<%= render "shared/navbar" %>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="container" style="position:relative;">
    <div class="hero-badge animate-fade-in">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      <span>Fast & reliable downloads</span>
    </div>

    <h1 class="hero-title animate-slide-up">
      Download Instagram<br>content <span class="highlight">instantly</span>
    </h1>

    <p class="hero-subtitle animate-slide-up">
      Photos, videos, reels, stories and more. No login required.<br>
      The fastest and cleanest Instagram downloader on the web.
    </p>

    <div class="animate-slide-up">
      <form action="<%= download_path %>" method="get" class="url-input-wrap">
        <span class="input-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </span>
        <input type="text" name="url" placeholder="Paste Instagram URL here..." autocomplete="off">
        <button type="submit" class="submit-btn">Download</button>
      </form>
    </div>

    <div class="hero-stats animate-fade-in">
      <div class="hero-stat">
        <span class="hero-stat-value">2M+</span>
        <span class="hero-stat-label">Downloads</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-value">150K+</span>
        <span class="hero-stat-label">Users</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-value">99.9%</span>
        <span class="hero-stat-label">Uptime</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-value">&lt;2s</span>
        <span class="hero-stat-label">Avg Speed</span>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="section section-sage" id="features">
  <div class="container">
    <div class="section-header">
      <h2>Everything you need</h2>
      <p>One platform for all your Instagram download and analysis needs</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <h3>Photo & Video</h3>
        <p>Download posts, reels, carousels in full quality</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h3>Profile Pictures</h3>
        <p>Get full-size profile pictures instantly</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <h3>Stories</h3>
        <p>Save stories before they disappear</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <h3>Profile Analyzer</h3>
        <p>Get detailed insights on any public profile</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:var(--sand-soft);color:#B8860B;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v12M6 12h12"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <h3>Influencer Search</h3>
        <p>Find influencers by niche and engagement</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:var(--sand-soft);color:#B8860B;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
        </div>
        <h3>Hashtag Generator</h3>
        <p>AI-powered hashtags for maximum reach</p>
      </div>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="section" id="pricing">
  <div class="container">
    <div class="section-header">
      <h2>Simple, honest pricing</h2>
      <p>No hidden fees. Cancel anytime. Start free.</p>
    </div>

    <div class="pricing-grid">
      <!-- Free -->
      <div class="pricing-card">
        <div class="plan-header">
          <h3>Free</h3>
          <div class="plan-price">
            <span class="price">Free</span>
          </div>
        </div>
        <ul class="plan-features">
          <li><span class="icon-check">&#10003;</span> Basic quality downloads</li>
          <li><span class="icon-check">&#10003;</span> Profile picture download</li>
          <li><span class="icon-check">&#10003;</span> Ad-supported</li>
          <li class="disabled"><span class="icon-x">&#10005;</span> Full quality & batch</li>
          <li class="disabled"><span class="icon-x">&#10005;</span> Stories downloader</li>
          <li class="disabled"><span class="icon-x">&#10005;</span> Profile analyzer</li>
        </ul>
        <a href="<%= download_path %>" class="plan-cta">Start Free &rarr;</a>
      </div>

      <!-- Basic -->
      <div class="pricing-card popular">
        <div class="popular-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Most Popular
        </div>
        <div class="plan-header">
          <h3>Basic</h3>
          <div class="plan-price">
            <span class="price">$4</span>
            <span class="period">/mo</span>
          </div>
        </div>
        <ul class="plan-features">
          <li><span class="icon-check">&#10003;</span> Full quality downloads</li>
          <li><span class="icon-check">&#10003;</span> Batch download</li>
          <li><span class="icon-check">&#10003;</span> Profile pictures</li>
          <li><span class="icon-check">&#10003;</span> Stories downloader</li>
          <li><span class="icon-check">&#10003;</span> Profile analyzer</li>
          <li><span class="icon-check">&#10003;</span> No ads</li>
        </ul>
        <a href="<%= pricing_path %>" class="plan-cta primary">Get Started &rarr;</a>
      </div>

      <!-- Pro -->
      <div class="pricing-card gold">
        <div class="plan-header">
          <h3>Pro</h3>
          <div class="plan-price">
            <span class="price">$9</span>
            <span class="period">/mo</span>
          </div>
        </div>
        <ul class="plan-features">
          <li><span class="icon-check">&#10003;</span> Everything in Basic</li>
          <li><span class="icon-check">&#10003;</span> Influencer search</li>
          <li><span class="icon-check">&#10003;</span> Hashtag generator</li>
          <li><span class="icon-check">&#10003;</span> Priority processing</li>
          <li><span class="icon-check">&#10003;</span> API access</li>
          <li><span class="icon-check">&#10003;</span> No ads</li>
        </ul>
        <a href="<%= pricing_path %>" class="plan-cta">Get Started &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-card">
      <h2>Ready to download?</h2>
      <p>Start downloading Instagram content for free. No sign-up required.</p>
      <a href="<%= download_path %>" class="cta-btn">
        Start Downloading &rarr;
      </a>
    </div>
  </div>
</section>

<%= render "shared/footer" %>

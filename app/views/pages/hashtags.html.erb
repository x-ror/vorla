<% content_for(:title) { "Hashtag Generator - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="hashtags">
  <div class="page-header container-sm">
    <div class="page-icon pro">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
    </div>
    <h1>Hashtag Generator</h1>
    <p>Generate optimized hashtags for maximum reach and engagement</p>
  </div>

  <div class="container-sm content-center">
    <form data-action="submit->hashtags#generate" class="url-input-wrap" style="max-width:540px;">
      <span class="input-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </span>
      <input type="text" data-hashtags-target="topic" placeholder="Enter a topic or keyword..." autocomplete="off">
      <button type="submit" class="submit-btn" data-hashtags-target="submitBtn">Generate</button>
    </form>

    <div class="quick-topics">
      <% %w[Fashion Food Travel Fitness Photography Tech Beauty Art].each do |t| %>
        <button type="button" class="topic-pill" data-action="click->hashtags#selectTopic" data-topic="<%= t %>"><%= t %></button>
      <% end %>
    </div>

    <div data-hashtags-target="error" style="display:none;" class="alert alert-error"></div>
    <div data-hashtags-target="result" style="display:none;"></div>
  </div>
</div>

<%= render "shared/footer" %>

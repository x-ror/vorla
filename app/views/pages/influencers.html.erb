<% content_for(:title) { "Influencer Search - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="influencers">
  <div class="page-header container-sm">
    <div class="page-icon pro">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v12M6 12h12"/><circle cx="12" cy="12" r="10"/></svg>
    </div>
    <h1>Influencer Search</h1>
    <p>Find influencers by niche, engagement rate, and follower count</p>
  </div>

  <div class="container" style="max-width:800px;">
    <form data-action="submit->influencers#search" class="url-input-wrap" style="margin-bottom:20px;">
      <span class="input-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </span>
      <input type="text" data-influencers-target="query" placeholder="Search by keyword, niche, or username..." autocomplete="off">
      <button type="submit" class="submit-btn" data-influencers-target="submitBtn">Search</button>
    </form>

    <div class="categories" style="margin-bottom:20px;">
      <% %w[All Fashion Fitness Food Travel Tech Beauty Lifestyle].each_with_index do |cat, i| %>
        <button type="button" class="cat-pill <%= 'active' if i == 0 %>" data-action="click->influencers#selectCategory" data-category="<%= cat.downcase %>"><%= cat %></button>
      <% end %>
    </div>

    <div data-influencers-target="result">
      <div class="empty-state">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v12M6 12h12"/><circle cx="12" cy="12" r="10"/></svg>
        <h3>Search for influencers</h3>
        <p>Enter a keyword or select a category to find relevant influencers</p>
      </div>
    </div>
  </div>
</div>

<%= render "shared/footer" %>

<% content_for(:title) { "Profile Picture Downloader - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="profile-picture">
  <div class="page-header container-sm">
    <div class="page-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <h1>Profile Picture Downloader</h1>
    <p>Get any Instagram profile picture in full HD resolution</p>
  </div>

  <div class="container-sm content-center">
    <form data-action="submit->profile-picture#fetch" class="username-input-wrap">
      <span class="at-sign">@</span>
      <input type="text" data-profile-picture-target="username" placeholder="username or Instagram URL" autocomplete="off">
      <button type="submit" class="search-btn" data-profile-picture-target="submitBtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>

    <div data-profile-picture-target="error" style="display:none;" class="alert alert-error"></div>
    <div data-profile-picture-target="result" style="display:none;"></div>
  </div>
</div>

<%= render "shared/footer" %>

<% content_for(:title) { "Stories Downloader - Vorla" } %>

<%= render "shared/navbar" %>

<div class="flex-1 pb-10" data-controller="stories">
  <div class="mx-auto max-w-2xl px-4 pt-16 text-center">
    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    </div>
    <h1 class="text-2xl font-extrabold tracking-tight">Stories Downloader</h1>
    <p class="mt-2 text-muted-foreground">Download Instagram stories before they disappear forever</p>
  </div>

  <div class="mx-auto mt-8 flex max-w-2xl flex-col items-center gap-6 px-4">
    <form data-action="submit->stories#fetch" class="flex w-full max-w-xl items-center gap-2 rounded-lg border-2 border-input bg-card p-1 transition-all focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/10">
      <span class="pl-4 font-semibold text-muted-foreground">@</span>
      <input type="text" data-stories-target="username" placeholder="username" autocomplete="off" class="flex-1 border-0 bg-transparent py-3 text-sm outline-none placeholder:text-muted-foreground">
      <button type="submit" data-stories-target="submitBtn" class="flex h-11 w-11 items-center justify-center rounded-md bg-primary text-primary-foreground transition-colors hover:bg-primary/90 disabled:opacity-50">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>

    <div data-stories-target="error" style="display:none;" class="alert alert-error"></div>
    <div data-stories-target="result" style="display:none;"></div>
  </div>
</div>

<%= render "shared/footer" %>

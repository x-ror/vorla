<% content_for(:title) { "Stories Downloader - Vorla" } %>

<%= render "shared/navbar" %>

<div class="page-body" data-controller="stories">
  <div class="page-header container-sm">
    <div class="page-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    </div>
    <h1>Stories Downloader</h1>
    <p>Download Instagram stories before they disappear forever</p>
  </div>

  <div class="container-sm content-center">
    <form data-action="submit->stories#fetch" class="username-input-wrap">
      <span class="at-sign">@</span>
      <input type="text" data-stories-target="username" placeholder="username" autocomplete="off">
      <button type="submit" class="search-btn" data-stories-target="submitBtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>

    <div data-stories-target="error" style="display:none;" class="alert alert-error"></div>
    <div data-stories-target="result" style="display:none;"></div>
  </div>
</div>

<%= render "shared/footer" %>

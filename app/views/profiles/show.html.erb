<% content_for(:title) { "#{t("user_pages.profile.title")} - X-ROR" } %>
<%= render "shared/navbar" %>
<main class="flex-1 bg-muted/50 pb-16 dark:bg-background">
  <div class="mx-auto max-w-3xl px-6 pt-12">
    <p class="text-xs font-medium uppercase tracking-widest text-muted-foreground"><%= t("user_pages.profile.section") %></p>
    <h1 class="mt-1 text-3xl font-normal tracking-tight"><%= t("user_pages.profile.title") %></h1>
    <%# ══ Card 1 — Identity ══ %>
    <%= form_with model: @user, url: profile_path, method: :patch, multipart: true, data: { controller: "profile-edit avatar" }, class: "mt-10" do |f| %>
      <div class="rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none">
        <div class="flex items-center justify-between border-b border-border px-6 py-4">
          <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground"><%= t("user_pages.profile.identity") %></span>
          <div class="flex gap-2">
            <button type="button" data-action="click->profile-edit#edit" data-profile-edit-target="editBtn" class="rounded-lg bg-primary px-5 py-2 text-xs font-semibold tracking-wide text-primary-foreground transition-colors hover:bg-primary/90"><%= t("user_pages.profile.edit_profile") %></button>
            <button type="submit" data-profile-edit-target="saveBtn" class="hidden rounded-lg bg-primary px-5 py-2 text-xs font-semibold tracking-wide text-primary-foreground transition-colors hover:bg-primary/90"><%= t("user_pages.profile.save_changes") %></button>
            <button type="button" data-action="click->profile-edit#cancel" data-profile-edit-target="cancelBtn" class="hidden rounded-lg border border-border px-5 py-2 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground"><%= t("common.cancel") %></button>
          </div>
        </div>
        <div class="flex gap-8 p-6">
          <%# Avatar column %>
          <div class="shrink-0">
            <input type="file" name="user[avatar]" accept="image/*" class="sr-only" data-avatar-target="input" data-action="change->avatar#preview">
            <button type="button" data-action="click->avatar#pick" data-profile-edit-target="avatarBtn" disabled class="group relative h-24 w-24 overflow-hidden rounded-full border-2 border-border transition-colors enabled:cursor-pointer enabled:hover:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, class: "h-full w-full object-cover transition-[filter] duration-200 group-[:not(:disabled):hover]:brightness-50", data: { avatar_target: "preview" } %>
              <% else %>
                <img src="" alt="" class="hidden h-full w-full object-cover" data-avatar-target="preview">
                <span class="flex h-full w-full items-center justify-center bg-secondary text-2xl font-semibold text-muted-foreground transition-colors duration-200 group-[:not(:disabled):hover]:bg-secondary/70" data-avatar-target="placeholder"><%= @user.email_address&.first&.upcase %></span>
              <% end %>
              <span class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200 group-[:not(:disabled):hover]:opacity-100">
                <%= lucide_icon("camera", class: "h-5 w-5 text-white") %>
              </span>
            </button>
            <% if @user.avatar.attached? %>
              <div class="mt-2 text-center">
                <%= link_to t("common.remove"), remove_avatar_profile_path, data: { turbo_method: :delete }, class: "text-xs text-destructive/70 transition-colors hover:text-destructive" %>
              </div>
            <% end %>
          </div>
          <%# Fields column %>
          <div class="flex-1 space-y-4">
            <div>
              <label for="full_name" class="mb-2 block text-xs font-medium uppercase tracking-wider text-muted-foreground"><%= t("user_pages.profile.full_name_label") %> <span class="normal-case tracking-normal font-light opacity-40"><%= t("user_pages.profile.full_name_optional") %></span></label>
              <input type="text" name="user[full_name]" id="full_name" value="<%= @user.full_name %>" data-original="<%= @user.full_name %>" data-profile-edit-target="field" placeholder="<%= t("user_pages.profile.full_name_label") %>" disabled class="w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm transition-all placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 disabled:cursor-default disabled:bg-transparent disabled:opacity-40">
            </div>
            <div>
              <label for="email" class="mb-2 block text-xs font-medium uppercase tracking-wider text-muted-foreground"><%= t("user_pages.profile.email_label") %></label>
              <input type="email" id="email" value="<%= @user.email_address %>" disabled class="w-full rounded-lg border border-input bg-transparent px-3.5 py-2.5 text-sm opacity-40 cursor-default">
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <%# ══ Card 2 — Connected accounts ══ %>
    <div class="mt-3.5 rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none">
      <div class="border-b border-border px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground"><%= t("user_pages.profile.connected_accounts") %></span>
      </div>
      <div class="px-6 py-2">
        <div class="flex items-center gap-4 py-4">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background">
            <%= lucide_icon("instagram", class: "h-4 w-4 text-pink-500") %>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium"><%= t("user_pages.profile.instagram") %></p>
            <% if @user.instagram_username.present? %>
              <p class="text-xs text-muted-foreground"><%= t("user_pages.profile.connected_as", username: @user.instagram_username) %></p>
            <% else %>
              <p class="text-xs text-muted-foreground"><%= t("user_pages.profile.not_connected") %></p>
            <% end %>
          </div>
          <% if @user.instagram_username.present? %>
            <span class="rounded bg-green-500/10 px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-green-500"><%= t("common.active") %></span>
            <%= button_to disconnect_instagram_profile_path, method: :delete, class: "rounded-lg border border-green-500/20 bg-green-500/5 px-3.5 py-1.5 text-xs font-medium text-green-500 transition-colors hover:bg-green-500/10" do %>
              <%= t("common.disconnect") %>
            <% end %>
          <% else %>
            <span class="rounded bg-muted px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-muted-foreground"><%= t("common.off") %></span>
            <button type="button" onclick="document.getElementById('ig-connect-form').classList.toggle('hidden')" class="rounded-lg border border-border px-3.5 py-1.5 text-xs font-medium text-muted-foreground transition-colors hover:border-primary/30 hover:text-primary"><%= t("common.connect") %></button>
          <% end %>
        </div>
        <% unless @user.instagram_username.present? %>
          <%= form_with url: connect_instagram_profile_path, method: :post, id: "ig-connect-form", class: "hidden border-t border-border py-4" do %>
            <div class="flex items-end gap-3">
              <div class="flex-1">
                <label for="instagram_username" class="mb-2 block text-xs font-medium uppercase tracking-wider text-muted-foreground"><%= t("user_pages.profile.instagram_username_label") %></label>
                <div class="flex items-center rounded-lg border border-input bg-background transition-colors focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20">
                  <span class="pl-3 text-sm text-muted-foreground">@</span>
                  <input type="text" name="instagram_username" id="instagram_username" placeholder="<%= t("user_pages.profile.instagram_username_placeholder") %>" autocomplete="off" class="flex-1 border-0 bg-transparent px-2 py-2.5 text-sm outline-none placeholder:text-muted-foreground">
                </div>
              </div>
              <button type="submit" class="rounded-lg bg-primary px-5 py-2.5 text-xs font-semibold text-primary-foreground transition-colors hover:bg-primary/90"><%= t("common.connect") %></button>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</main>
<%= render "shared/footer" %>

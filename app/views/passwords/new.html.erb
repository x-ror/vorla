<% content_for(:title) { t("auth.forgot_password.title") } %>

<main class="flex min-h-screen items-center justify-center px-4 py-10">
  <div class="w-full max-w-sm animate-slide-up">
    <%= render_card(class: "w-full") do %>
      <div class="p-8">
        <div class="mb-8 text-center">
          <a href="<%= root_path %>" class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary text-primary-foreground font-extrabold text-xl mb-6" aria-label="X-ROR home">X</a>
          <h1 class="text-xl font-extrabold tracking-tight"><%= t("auth.forgot_password.heading") %></h1>
          <p class="mt-1 text-sm text-muted-foreground"><%= t("auth.forgot_password.subheading") %></p>
        </div>

        <%= form_with url: passwords_path, class: "space-y-5" do |form| %>
          <div class="space-y-1.5">
            <label for="reset-email" class="text-sm font-medium"><%= t("auth.forgot_password.email_label") %></label>
            <%= render_input name: "email_address", id: "reset-email", type: :email, placeholder: t("auth.forgot_password.email_placeholder"), autocomplete: "username", required: true, value: params[:email_address] %>
          </div>

          <%= render_button t("auth.forgot_password.submit"), class: "w-full" %>
        <% end %>

        <div class="mt-6 text-center text-sm text-muted-foreground">
          <%= t("auth.forgot_password.remember") %> <a href="<%= login_path %>" class="font-semibold text-primary hover:underline focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm"><%= t("auth.forgot_password.sign_in_link") %></a>
        </div>
      </div>
    <% end %>
  </div>
</main>

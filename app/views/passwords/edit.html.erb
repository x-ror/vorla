<% content_for(:title) { t("auth.update_password.title") } %>

<main class="flex min-h-screen items-center justify-center px-4 py-10">
  <div class="w-full max-w-sm animate-slide-up">
    <%= render_card(class: "w-full") do %>
      <div class="p-8">
        <div class="mb-8 text-center">
          <a href="<%= root_path %>" class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary text-primary-foreground font-extrabold text-xl mb-6" aria-label="X-ROR home">X</a>
          <h1 class="text-xl font-extrabold tracking-tight"><%= t("auth.update_password.heading") %></h1>
          <p class="mt-1 text-sm text-muted-foreground"><%= t("auth.update_password.subheading") %></p>
        </div>

        <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
          <div class="space-y-1.5">
            <label for="new-password" class="text-sm font-medium"><%= t("auth.update_password.new_password_label") %></label>
            <%= render_input name: "password", id: "new-password", type: :password, placeholder: t("auth.update_password.new_password_placeholder"), autocomplete: "new-password", required: true %>
          </div>

          <div class="space-y-1.5">
            <label for="confirm-password" class="text-sm font-medium"><%= t("auth.update_password.confirm_label") %></label>
            <%= render_input name: "password_confirmation", id: "confirm-password", type: :password, placeholder: t("auth.update_password.confirm_placeholder"), autocomplete: "new-password", required: true %>
          </div>

          <%= render_button t("auth.update_password.submit"), class: "w-full" %>
        <% end %>
      </div>
    <% end %>
  </div>
</main>

<% content_for(:title) { "Security - Vorla" } %>

<%= render "shared/navbar" %>

<main class="flex-1 bg-muted/50 pb-16 dark:bg-background">
  <div class="mx-auto max-w-3xl px-6 pt-12">

    <p class="text-xs font-medium uppercase tracking-widest text-muted-foreground">Account</p>
    <h1 class="mt-1 text-3xl font-normal tracking-tight">Security</h1>

    <%# ══ Card 1 — Active Sessions ══ %>
    <div class="mt-10 rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none">
      <div class="flex items-center justify-between border-b border-border px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground">Active sessions</span>
        <% if @sessions.size > 1 %>
          <%= button_to "Revoke all others", destroy_all_active_sessions_path, method: :delete,
            class: "text-xs font-medium text-destructive transition-opacity hover:opacity-70",
            data: { turbo_confirm: "Revoke all other sessions?" } %>
        <% end %>
      </div>

      <div class="divide-y divide-border">
        <% @sessions.each do |sess| %>
          <div class="flex items-center gap-4 px-6 py-4">
            <%# Device icon %>
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background">
              <svg class="h-4 w-4 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <% if sess.device_name == "iPhone" || sess.device_name == "iPad" || sess.device_name == "Android" %>
                  <rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/>
                <% else %>
                  <rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>
                <% end %>
              </svg>
            </div>

            <%# Info %>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="text-sm font-medium"><%= sess.browser_name %> on <%= sess.device_name %></p>
                <% if sess == @current_session %>
                  <span class="rounded bg-primary/10 px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-primary">This device</span>
                <% end %>
              </div>
              <p class="text-xs text-muted-foreground"><%= sess.ip_address %> &middot; <%= sess == @current_session ? "Active now" : "#{time_ago_in_words(sess.created_at)} ago" %></p>
            </div>

            <%# Action %>
            <% if sess == @current_session %>
              <span class="rounded bg-primary/10 px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-primary">Active</span>
            <% else %>
              <%= button_to active_session_path(sess), method: :delete,
                class: "text-xs font-medium text-destructive/70 transition-colors hover:text-destructive",
                data: { turbo_confirm: "Revoke this session?" } do %>
                Revoke
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ══ Card 2 — Passkeys ══ %>
    <div class="mt-3.5 rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none" data-controller="passkey">
      <div class="border-b border-border px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground">Passkeys</span>
      </div>

      <div class="px-6 py-4">
        <% if @passkey_credentials.any? %>
          <div class="divide-y divide-border mb-4">
            <% @passkey_credentials.each do |cred| %>
              <div class="flex items-center gap-4 py-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background">
                  <svg class="h-4 w-4 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10v4"/><path d="M7.5 7.5c.7-.7 1.5-1 2.5-1a3.5 3.5 0 0 1 0 7H9"/><path d="M2 12a10 10 0 1 0 20 0 10 10 0 1 0-20 0"/></svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium"><%= cred.nickname %></p>
                  <p class="text-xs text-muted-foreground">Added <%= time_ago_in_words(cred.created_at) %> ago</p>
                </div>
                <%= button_to passkey_path(cred), method: :delete,
                  class: "text-xs font-medium text-destructive/70 transition-colors hover:text-destructive",
                  data: { turbo_confirm: "Remove this passkey?" } do %>
                  Remove
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <button type="button" data-action="click->passkey#register"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
          Add a passkey
        </button>

        <p class="mt-2 text-xs text-muted-foreground" data-passkey-target="status"></p>
      </div>
    </div>

    <%# ══ Card 3 — Password ══ %>
    <div class="mt-3.5 rounded-xl border border-border/80 bg-card shadow-md dark:shadow-none">
      <div class="border-b border-border px-6 py-4">
        <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground">Password</span>
      </div>

      <div class="flex items-center justify-between px-6 py-5">
        <p class="text-sm text-muted-foreground">Reset your password via email</p>
        <%= link_to new_password_path, class: "rounded-lg border border-border px-4 py-2 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground" do %>
          Reset password
        <% end %>
      </div>
    </div>

  </div>
</main>

<%= render "shared/footer" %>

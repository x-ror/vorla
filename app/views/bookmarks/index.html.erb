<% content_for(:title) { "Bookmarks - X-ROR" } %>
<%= render "shared/navbar" %>
<main class="flex-1 pb-10">
  <div class="mx-auto max-w-2xl px-4 pt-16 text-center">
    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary" aria-hidden="true">
      <%= lucide_icon("bookmark", class: "h-6 w-6") %>
    </div>
    <h1 class="text-2xl font-extrabold tracking-tight">Bookmarks</h1>
    <p class="mt-2 text-muted-foreground">Your saved Instagram links and accounts</p>
    <% if @bookmark_limit %>
      <p class="mt-2 text-xs text-muted-foreground"><%= @bookmark_count %>/<%= @bookmark_limit %> bookmarks used</p>
    <% end %>
  </div>

  <div class="mx-auto max-w-xl px-4 mt-8">
    <%# Type filter tabs %>
    <div class="flex gap-1 mb-6">
      <%= link_to "All", bookmarks_path, class: "rounded-md px-3 py-1.5 text-xs font-medium transition-colors #{params[:type].blank? ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground'}" %>
      <% Bookmark::TYPES.each do |type| %>
        <%= link_to type.capitalize, bookmarks_path(type: type), class: "rounded-md px-3 py-1.5 text-xs font-medium transition-colors #{params[:type] == type ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground'}" %>
      <% end %>
    </div>

    <% if @bookmarks.any? %>
      <div class="space-y-2">
        <% @bookmarks.each do |bookmark| %>
          <%= render_card do %>
            <div class="flex items-center gap-4 p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background">
                <%= lucide_icon(bookmark_type_icon(bookmark.bookmark_type), class: "h-4 w-4 text-pink-500") %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium truncate"><%= bookmark.title.presence || bookmark.url %></p>
                <p class="text-xs text-muted-foreground">
                  <span class="rounded bg-muted px-1.5 py-0.5 text-xs font-medium"><%= bookmark.bookmark_type.capitalize %></span>
                  <% if bookmark.instagram_username.present? %>
                    &middot; @<%= bookmark.instagram_username %>
                  <% end %>
                  &middot; <%= time_ago_in_words(bookmark.created_at) %> ago
                </p>
              </div>
              <div class="flex items-center gap-1">
                <a href="<%= bookmark.url %>" target="_blank" rel="noopener" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground" aria-label="Open in Instagram">
                  <%= lucide_icon("external-link", class: "h-4 w-4") %>
                </a>
                <%= link_to bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Remove this bookmark?" }, class: "inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-destructive/10 hover:text-destructive", aria_label: "Remove bookmark" do %>
                  <%= lucide_icon("trash-2", class: "h-4 w-4") %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <%= lucide_icon("bookmark", class: "mx-auto h-10 w-10 text-muted-foreground/30 mb-3") %>
        <p class="text-sm text-muted-foreground">No bookmarks yet. Use the bookmark button on any result to save it here.</p>
      </div>
    <% end %>
  </div>
</main>
<%= render "shared/footer" %>
